{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/**/*.ts": {
      "includeFiles": "server/**/*.ts,shared/**/*.ts"
    }
  },
  "rewrites": [
    {
      "source": "/((?!api|assets|favicon\\.svg|logo-iso\\.png|lottie-shield\\.json|robots\\.txt|site\\.webmanifest|sitemap\\.xml).*)",
      "destination": "/index.html"
    }
  ]
}
